# ============================================================
# Deploy to:  /etc/aide/aide.conf.d/99-hardening
# Apply:      sudo aide --init --config /etc/aide/aide.conf
#             sudo mv /var/lib/aide/aide.db.new /var/lib/aide/aide.db
# Module:     hardening
# Requires:   none
#
# AIDE file integrity monitoring — critical paths (FINT-4350 Lynis baseline)
# Parameters modified from baseline:  none
#
# Purpose:    Defines monitored paths and the CONTENTEX group for file
#             integrity checks. CONTENTEX is not built-in on Ubuntu/Debian —
#             equivalent to checksum + perms + owner + inode + acl + xattrs.
# Note:       retcode 17 on init is expected — AIDE cannot read root-only
#             files (/etc/shadow, /root/). DB is generated correctly regardless.
#             Underscore characters in group names are deprecated in AIDE
#             0.18.6+ — use alphanumeric names only (CONTENTEX).
# ============================================================

# Group definition — content + extended attributes
CONTENTEX = p+ftype+i+l+n+u+g+s+sha256+acl+xattrs

/etc/ssh        CONTENTEX
/etc/sudoers    CONTENTEX
/etc/sudoers.d  CONTENTEX
/etc/pam.d      CONTENTEX
/etc/audit      CONTENTEX
/etc/sysctl.d   CONTENTEX
/etc/modprobe.d CONTENTEX
/etc/fail2ban   CONTENTEX
# WireGuard (conditional — only if Step 5 was deployed)
# Remove this line if WireGuard was not installed — AIDE fails init
# with exit code 1 if a monitored path does not exist on the filesystem.
/etc/wireguard  CONTENTEX
/bin            CONTENTEX
/sbin           CONTENTEX
/usr/bin        CONTENTEX
/usr/sbin       CONTENTEX
/usr/lib/systemd/system CONTENTEX
/boot           CONTENTEX