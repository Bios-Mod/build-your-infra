# ============================================================
# Deploy to:  /etc/audit/rules.d/99-hardening.rules
# Apply:      sudo augenrules --load
# Module:     hardening
# Requires:   none
#
# auditd rules — privileged commands, identity, network, file deletion
# Parameters modified from baseline:  none
#
# Platform:   Ubuntu Server 24.04 LTS · ARM64 (aarch64)
# Note:       -e 2 (immutable mode) requires a reboot to modify rules after
#             load. Always verify with auditctl -l before applying in prod.
#             All comments must be ASCII-only — auditd silently stops parsing
#             at the first non-ASCII character.
#             ARM64: unlink and rename are legacy x86 syscalls, not present
#             on aarch64. Use unlinkat/renameat/renameat2. b32 rules are
#             harmless on ARM64 (no match, ignored).
# Verify:     sudo auditctl -l
# ============================================================

# Clear pre-boot rules
-D

# Event buffer -- increased to avoid losing events under load
-b 8192

# Log changes to critical authentication files
-w /etc/passwd -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/group -p wa -k identity
-w /etc/sudoers -p wa -k identity
-w /etc/sudoers.d/ -p wa -k identity

# Log changes to PAM configuration (authentication module stack)
# /etc/pam.d/ modification can inject rogue modules, bypass authentication,
# or silently log credentials. Not in CIS L1 standard rules -- added because
# PAM controls every authentication event on this server.
-w /etc/pam.d/ -p wa -k pam_config

# Log changes to SSH configuration
-w /etc/ssh/sshd_config -p wa -k sshd_config

# Log privileged command usage
-w /bin/su -p x -k privileged
-w /usr/bin/sudo -p x -k privileged

# Log changes to network configuration
-w /etc/netplan/ -p wa -k network_config
-w /etc/hosts -p wa -k network_config

# Log modifications to the audit system itself
-w /etc/audit/ -p wa -k audit_config
-w /sbin/auditctl -p x -k audit_tools
-w /sbin/auditd -p x -k audit_tools

# Log mount system calls -- user-initiated only
# auid>=1000 excludes system/daemon mounts
# auid!=4294967295 excludes processes with no login session
-a always,exit -F arch=b64 -S mount -F auid>=1000 -F auid!=4294967295 -k mounts
-a always,exit -F arch=b32 -S mount -F auid>=1000 -F auid!=4294967295 -k mounts

# Log file deletion and rename operations -- user-initiated only
# ARM64 note: unlink and rename are not valid syscall names on aarch64.
# Only unlinkat, renameat, renameat2 exist in the ARM64 ABI.
# x86_64 equivalent would also include: unlink, rename
-a always,exit -F arch=b64 -S unlinkat -S renameat -S renameat2 -F auid>=1000 -F auid!=4294967295 -k file_deletion
-a always,exit -F arch=b32 -S unlinkat -S renameat -S renameat2 -F auid>=1000 -F auid!=4294967295 -k file_deletion

# Log changes to WireGuard VPN configuration (contains private keys)
# Conditional -- only applies if Step 5 (WireGuard) was deployed.
# auditd emits a warning on load if the watched path does not exist.
-w /etc/wireguard/ -p wa -k vpn_config

# Log changes to cron configuration (persistence vector)
-w /etc/crontab -p wa -k cron_config
-w /etc/cron.d/ -p wa -k cron_config
-w /etc/cron.daily/ -p wa -k cron_config
-w /etc/cron.hourly/ -p wa -k cron_config
-w /etc/cron.weekly/ -p wa -k cron_config
-w /etc/cron.monthly/ -p wa -k cron_config

# Make rules immutable until the next reboot
-e 2