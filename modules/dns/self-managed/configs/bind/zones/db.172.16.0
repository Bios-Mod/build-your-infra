$TTL    604800
@   IN  SOA ns1.lab.internal. admin.lab.internal. (
                  2026053001 ; Serial
                  604800     ; Refresh
                  86400      ; Retry
                  2419200    ; Expire
                  604800 )   ; Negative cache TTL

; Name servers
@       IN  NS  ns1.lab.internal.

; PTR records — last octet of WireGuard IP
1       IN  PTR ns1.lab.internal.
1       IN  PTR vps.lab.internal.