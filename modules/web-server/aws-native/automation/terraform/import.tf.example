# Deploy to:   modules/web-server/aws-native/automation/terraform/
# Apply:       copy to import.tf, fill in real IDs, delete after apply
# Module:      web-server / aws-native
# Requires:    aws-native.md — all steps completed. ACM certificate Issued.
#
# Import blocks for existing web server resources.
# Parameters modified from baseline:  none — import only, no resource changes.
#
# Note:        This file holds both provider alias declarations during Phase 1.
#              main.tf does not exist at this stage — provider blocks live here.
#              Delete this file after terraform apply completes (Step 5).

terraform {
  required_version = ">= 1.15.6"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 6.50"
    }
  }
}

provider "aws" {
  region  = var.aws_region
  profile = var.aws_profile
}

provider "aws" {
  alias   = "us_east_1"
  region  = "us-east-1"
  profile = var.aws_profile
}

# ── ACM certificate (us-east-1) ───────────────────────────────────────────────
import {
  to = aws_acm_certificate.main
  id = "<arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/UUID>"
}

# ── S3 origin bucket ──────────────────────────────────────────────────────────
import {
  to = aws_s3_bucket.web_origin
  id = "multi-lab-web-origin-<account-id>"
}

import {
  to = aws_s3_bucket_public_access_block.web_origin
  id = "multi-lab-web-origin-<account-id>"
}

import {
  to = aws_s3_bucket_policy.web_origin
  id = "multi-lab-web-origin-<account-id>"
}

# ── CloudFront distribution ───────────────────────────────────────────────────
import {
  to = aws_cloudfront_distribution.main
  id = "<DISTRIBUTION_ID>"
}

# ── Route 53 Alias records ────────────────────────────────────────────────────
# Import ID format: ZONE_ID_FQDN_TYPE
# Example: Z1PA6795UKMFR9_buildyourinfra.click_A

import {
  to = aws_route53_record.apex
  id = "<ZONE_ID>_<DOMAIN_NAME>_A"
}

import {
  to = aws_route53_record.www
  id = "<ZONE_ID>_www.<DOMAIN_NAME>_A"
}