# Deploy to:   modules/file-transfer/aws-native/automation/terraform/
# Apply:       cp main.tf.example main.tf — activate after import cycle is complete
# Module:      modules/file-transfer/aws-native
# Requires:    terraform.tfvars, state populated via import cycle (see file-transfer-aws-native-automation.md)
#              If all resources were torn down, rename directly and run terraform apply.
#
# Full resource definition for the file-transfer aws-native module.
# Do not rename to main.tf until import.tf has been applied and deleted (import path).
# Parameters modified from baseline: none

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 6.50"
    }
  }
  required_version = ">= 1.15.6"
}

provider "aws" {
  region  = var.aws_region
  profile = var.aws_profile
}

# ── S3 BUCKET ─────────────────────────────────────────────────────────────────

resource "aws_s3_bucket" "transfer" {
  bucket = "multi-lab-transfer-${var.account_id}"
}

resource "aws_s3_bucket_public_access_block" "transfer" {
  bucket = aws_s3_bucket.transfer.id

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_versioning" "transfer" {
  bucket = aws_s3_bucket.transfer.id

  versioning_configuration {
    status     = "Enabled"
    mfa_delete = "Disabled"
  }
}

# ── IAM ROLE ──────────────────────────────────────────────────────────────────

resource "aws_iam_role" "transfer" {
  name = "multi-lab-transfer-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect    = "Allow"
      Principal = { Service = "transfer.amazonaws.com" }
      Action    = "sts:AssumeRole"
    }]
  })
}

resource "aws_iam_role_policy" "transfer_s3" {
  name = "multi-lab-transfer-s3-policy"
  role = aws_iam_role.transfer.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "AllowListBucket"
        Effect = "Allow"
        Action = [
          "s3:ListBucket",
          "s3:GetBucketLocation"
        ]
        Resource = aws_s3_bucket.transfer.arn
      },
      {
        Sid    = "AllowObjectOperations"
        Effect = "Allow"
        Action = [
          "s3:PutObject",
          "s3:GetObject",
          "s3:DeleteObject",
          "s3:DeleteObjectVersion",
          "s3:GetObjectVersion"
        ]
        Resource = "${aws_s3_bucket.transfer.arn}/*"
      }
    ]
  })
}

# ── SECURITY GROUP ────────────────────────────────────────────────────────────

resource "aws_security_group" "transfer" {
  name        = "multi-lab-transfer-sg"
  description = "SFTP access — operator IP only"
  vpc_id      = var.vpc_id

  ingress {
    description = "SFTP from operator IP"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = [var.operator_ip]
  }

  egress {
    description = "Allow all outbound"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

# ── CLOUDWATCH LOG GROUP ──────────────────────────────────────────────────────

resource "aws_cloudwatch_log_group" "transfer" {
  name              = "/aws/transfer/multi-lab-transfer"
  retention_in_days = 30
}

# ── TRANSFER FAMILY SERVER ────────────────────────────────────────────────────

resource "aws_transfer_server" "main" {
  protocols              = ["SFTP"]
  identity_provider_type = "SERVICE_MANAGED"
  endpoint_type          = "VPC"
  domain                 = "S3"
  security_policy_name   = "TransferSecurityPolicy-2024-01"

  endpoint_details {
    vpc_id                 = var.vpc_id
    subnet_ids             = [var.subnet_id]
    security_group_ids     = [aws_security_group.transfer.id]
    address_allocation_ids = [var.eip_allocation_id]
  }

  logging_role = null

  structured_log_destinations = [
    "${aws_cloudwatch_log_group.transfer.arn}:*"
  ]
}

# ── TRANSFER FAMILY USER ──────────────────────────────────────────────────────

resource "aws_transfer_user" "sftpuser" {
  server_id           = aws_transfer_server.main.id
  user_name           = "sftpuser"
  role                = aws_iam_role.transfer.arn
  home_directory_type = "LOGICAL"

  home_directory_mappings {
    entry  = "/"
    target = "/${aws_s3_bucket.transfer.bucket}/uploads"
  }
}

resource "aws_transfer_ssh_key" "sftpuser" {
  server_id = aws_transfer_server.main.id
  user_name = aws_transfer_user.sftpuser.user_name
  body      = var.sftp_public_key
}