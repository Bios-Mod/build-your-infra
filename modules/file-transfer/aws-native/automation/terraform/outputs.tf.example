# Deploy to:   modules/file-transfer/aws-native/automation/terraform/
# Apply:       copy to outputs.tf after import cycle completes — never commit outputs.tf
# Module:      file-transfer / aws-native
# Requires:    import cycle complete (Step 6)
#
# Outputs for the file-transfer aws-native Terraform module.
# Parameters modified from baseline: none

output "s3_bucket_name" {
  description = "Name of the Transfer Family S3 backend bucket."
  value       = aws_s3_bucket.transfer.bucket
}

output "iam_role_arn" {
  description = "ARN of the IAM role assumed by Transfer Family."
  value       = aws_iam_role.transfer.arn
}

output "security_group_id" {
  description = "ID of the Security Group restricting SFTP access."
  value       = aws_security_group.transfer.id
}

output "cloudwatch_log_group" {
  description = "CloudWatch log group receiving Transfer Family session events."
  value       = aws_cloudwatch_log_group.transfer.name
}

output "transfer_server_id" {
  description = "Transfer Family server ID."
  value       = aws_transfer_server.main.id
}

output "transfer_server_endpoint" {
  description = "SFTP endpoint hostname for client SSH config."
  value       = aws_transfer_server.main.endpoint
}